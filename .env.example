DIFY_SOURCE_DIR=../dify
DIFY_CONSOLE_API_BASE=http://localhost:5001/console/api
DIFY_CONSOLE_WEB_BASE=http://localhost:3000

# Required for POST /api/workflows/create against a real Dify instance.
DIFY_EMAIL=
DIFY_PASSWORD=
DIFY_LOGIN_LANGUAGE=en-US

# Used by the generated LLM nodes inside Dify.
DIFY_DEFAULT_MODEL_PROVIDER=langgenius/openai/openai
DIFY_DEFAULT_MODEL_NAME=gpt-4o-mini

# Optional. If omitted, chat2dify falls back to a deterministic simple workflow.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
